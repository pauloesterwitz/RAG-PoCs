# Copy this file to .env and fill in your values.
# config.py loads .env automatically on startup.

# One of these is required for provider=claude (the default):
# API key from console.anthropic.com:
ANTHROPIC_API_KEY=sk-ant-...
# OR: OAuth bearer token from your Claude Code session:
# ANTHROPIC_AUTH_TOKEN=<token>

# Optional overrides (defaults shown)
# RAG_PROVIDER=claude          # "claude" or "ollama"
# RAG_GEN_MODEL=claude-sonnet-4-6
# RAG_JUDGE_MODEL=claude-sonnet-4-6
# RAG_EMBED_MODEL=intfloat/multilingual-e5-small
# RAG_EMBED_DIM=384

# To switch back to Ollama:
# RAG_PROVIDER=ollama
# RAG_GEN_MODEL=qwen3.6:35b-a3b-q8_0
# RAG_JUDGE_MODEL=qwen3.6:35b-a3b-q8_0
# RAG_EMBED_MODEL=embeddinggemma:latest
# RAG_EMBED_DIM=768
